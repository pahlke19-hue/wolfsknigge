<style>
  /* Desktop: mittig rechts, Labels per Hover */
  .contact-sidebar {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .contact-btn {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 9px 12px 9px 10px;
    background: #f97316;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    white-space: nowrap;
    border-radius: 7px 0 0 7px;
    box-shadow: -2px 2px 12px rgba(0,0,0,0.35);
    transition: background 0.15s ease;
  }

  .contact-btn:hover,
  .contact-btn:focus-visible {
    background: #ea580c;
  }

  .contact-btn span {
    max-width: 0;
    overflow: hidden;
    display: inline-block;
    transition: max-width 0.25s ease;
  }

  .contact-btn:hover span,
  .contact-btn:focus-visible span {
    max-width: 80px;
  }

  .contact-btn:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  /* Mobil: Sidebar aus, unten greift die MobileBar */
  @media (max-width: 1023px) {
    .contact-sidebar {
      display: none;
    }
  }
</style>

<script>
  if (window.innerWidth <= 640) {
    const sidebar = document.querySelector('.contact-sidebar') as HTMLElement | null;
    if (sidebar) {

    let currentY = 0;
    let targetY = 0;
    let rafId: number;

    const getTargetY = () => {
      const scrollFraction = Math.min(window.scrollY / 300, 1);
      const vh = window.innerHeight;
      const sidebarH = sidebar.offsetHeight;
      // Start: vertikale Mitte; End: 20px über Unterkante
      const startY = (vh / 2) - (sidebarH / 2);
      const endY = vh - sidebarH - 90;
      return startY + (endY - startY) * scrollFraction;
    };

    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    const tick = () => {
      targetY = getTargetY();
      // Geschwindigkeit des Nachlaufens: höherer Wert = schneller/direkter
      currentY = lerp(currentY, targetY, 0.08);
      sidebar.style.transform = `translateY(${currentY}px)`;
      if (Math.abs(currentY - targetY) > 0.3) {
        rafId = requestAnimationFrame(tick);
      } else {
        sidebar.style.transform = `translateY(${targetY}px)`;
      }
    };

    // Init ohne Animation
    currentY = getTargetY();
    sidebar.style.transform = `translateY(${currentY}px)`;

    window.addEventListener('scroll', () => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(tick);
    }, { passive: true });

    window.addEventListener('resize', () => {
      currentY = getTargetY();
      sidebar.style.transform = `translateY(${currentY}px)`;
    });
    }
  }
</script>
