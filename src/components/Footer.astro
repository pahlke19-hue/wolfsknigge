---
interface Props {
  year?: number;
  landingPage?: boolean;
}

const { year = new Date().getFullYear(), landingPage = false } = Astro.props;
---

<footer class="bg-anthrazit-2 border-t border-white/4">
  <div class={`max-w-[1200px] mx-auto px-6 lg:px-8 ${landingPage ? 'py-8' : 'py-16'}`}>
    {!landingPage && (
      <>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div>
          <img src="/images/logo.svg" alt="WolfsKnigge" class="h-10 w-auto invert brightness-200 mb-4" />
          <p class="text-sm text-white/55 leading-relaxed">
            Mobile Hundeschule & Verhaltenstraining. Unterwegs in Kiel, Rendsburg, Eckernförde, Neumünster.
          </p>
          <div class="flex gap-3 mt-5">
            <a href="https://www.instagram.com/wolfsknigge/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-9 h-9 rounded-full bg-white/5 border border-white/8 flex items-center justify-center text-white/55 hover:text-orange hover:border-orange/30 transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.8.2 2.2.4.6.2 1 .5 1.4.9.4.4.7.8.9 1.4.2.4.3 1 .4 2.2.1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1.2-.2 1.8-.4 2.2-.2.6-.5 1-.9 1.4-.4.4-.8.7-1.4.9-.4.2-1 .3-2.2.4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1.2-.1-1.8-.2-2.2-.4-.6-.2-1-.5-1.4-.9-.4-.4-.7-.8-.9-1.4-.2-.4-.3-1-.4-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c.1-1.2.2-1.8.4-2.2.2-.6.5-1 .9-1.4.4-.4.8-.7 1.4-.9.4-.2 1-.3 2.2-.4C8.4 2.2 8.8 2.2 12 2.2m0-2.2C8.7 0 8.3 0 7.1.1 5.8.1 5 .3 4.2.6c-.8.3-1.5.7-2.2 1.4C1.3 2.7.9 3.4.6 4.2.3 5 .1 5.8.1 7.1 0 8.3 0 8.7 0 12s0 3.7.1 4.9c.1 1.3.2 2.1.5 2.9.3.8.7 1.5 1.4 2.2.7.7 1.4 1.1 2.2 1.4.8.3 1.6.5 2.9.5 1.2.1 1.6.1 4.9.1s3.7 0 4.9-.1c1.3-.1 2.1-.2 2.9-.5.8-.3 1.5-.7 2.2-1.4.7-.7 1.1-1.4 1.4-2.2.3-.8.5-1.6.5-2.9.1-1.2.1-1.6.1-4.9s0-3.7-.1-4.9c-.1-1.3-.2-2.1-.5-2.9-.3-.8-.7-1.5-1.4-2.2C21.3 1.3 20.6.9 19.8.6 19 .3 18.2.1 16.9.1 15.7 0 15.3 0 12 0zm0 5.8a6.2 6.2 0 100 12.4 6.2 6.2 0 000-12.4zm0 10.2a4 4 0 110-8 4 4 0 010 8zm6.4-11.8a1.4 1.4 0 100 2.8 1.4 1.4 0 000-2.8z"/></svg>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61574131065011" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-9 h-9 rounded-full bg-white/5 border border-white/8 flex items-center justify-center text-white/55 hover:text-orange hover:border-orange/30 transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12a12 12 0 10-13.9 11.9v-8.4H7.1V12h3V9.4c0-3 1.8-4.7 4.5-4.7 1.3 0 2.7.2 2.7.2v3h-1.5c-1.5 0-2 .9-2 1.9V12h3.4l-.5 3.5h-2.9v8.4A12 12 0 0024 12z"/></svg>
            </a>
            <a href="https://www.tiktok.com/@wolfsknigge" target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="w-9 h-9 rounded-full bg-white/5 border border-white/8 flex items-center justify-center text-white/55 hover:text-orange hover:border-orange/30 transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.6 6.3a5.3 5.3 0 01-3.4-1.3 5.4 5.4 0 01-1.8-3.3h-3.3v14.3a2.6 2.6 0 11-2.6-2.6c.3 0 .5 0 .8.1v-3.4a6 6 0 00-.8-.1 6 6 0 106 6V8.7a8.7 8.7 0 005.1 1.6V7a5.3 5.3 0 01-1-.7z"/></svg>
            </a>
          </div>
        </div>

        <div>
          <h3 class="text-white font-display font-bold text-base mb-4">Kontakt</h3>
          <address class="not-italic text-sm text-white/55 space-y-1 leading-[2]">
            <div>René Pahlke</div>
            <div>Katzheide 24, 24796 Bredenbek</div>
            <div class="pt-1">
              <a href="tel:+4915147736042" class="hover:text-white/60 transition-colors">01514 7736042</a>
            </div>
            <div>
              <a href="mailto:kontakt@wolfsknigge.de" class="hover:text-white/60 transition-colors">kontakt@wolfsknigge.de</a>
            </div>
          </address>
        </div>

        <div>
          <h3 class="text-white font-display font-bold text-base mb-4">Öffnungszeiten</h3>
          <ul class="text-sm text-white/55 space-y-1 leading-[2]">
            <li>Mo – Fr: 09:00 – 19:00</li>
            <li>Sa: 09:00 – 13:00</li>
            <li>So: geschlossen</li>
          </ul>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-white/4">
        <div class="text-[11px] uppercase tracking-[0.2em] text-white/30 font-semibold mb-3">Zahlungsarten</div>
        <div class="flex flex-wrap items-center gap-2">
          {[
            { src: "paypal.png", alt: "PayPal" },
            { src: "klarna.svg", alt: "Klarna" },
            { src: "visa.png", alt: "Visa" },
            { src: "mastercard.png", alt: "Mastercard" },
            { src: "apple-pay.png", alt: "Apple Pay" },
            { src: "google-pay.webp", alt: "Google Pay" },
          ].map((p) => (
            <div class="bg-white rounded-md h-7 px-2.5 flex items-center justify-center">
              <img src={`/images/zahlung/${p.src}`} alt={p.alt} class="max-h-4 w-auto" loading="lazy" />
            </div>
          ))}
          <span class="text-white/35 text-xs font-medium ml-1">u. a. auch Barzahlung</span>
        </div>
      </div>
      </>
    )}
    <div class="border-t border-white/4 mt-10 pt-6 flex flex-wrap justify-between gap-3 text-[13px] text-white/30">
      <span>WolfsKnigge © {year} – René Pahlke</span>
      <div class="flex gap-5">
        <a href="/agb" class="hover:text-white/50 transition-colors">AGB</a>
        <a href="/impressum" class="hover:text-white/50 transition-colors">Impressum</a>
        <a href="/dsgvo" class="hover:text-white/50 transition-colors">Datenschutz</a>
        <button type="button" onclick="window.openCookieSettings && window.openCookieSettings()" class="hover:text-white/50 transition-colors">Cookie-Einstellungen</button>
      </div>
    </div>
  </div>
</footer>
