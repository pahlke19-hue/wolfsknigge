---
// Sticky Kontakt-Leiste am unteren Bildschirmrand, nur mobil sichtbar.
---

<div class="fixed bottom-0 left-0 right-0 z-40 lg:hidden px-4 pb-[calc(14px+env(safe-area-inset-bottom,0px))] pt-3 bg-gradient-to-t from-anthrazit via-anthrazit/85 to-transparent pointer-events-none">
  <div class="max-w-[500px] mx-auto flex items-center justify-between gap-3 pointer-events-auto">

    <!-- WhatsApp CTA -->
    <a
      href="https://wa.me/4915147736042"
      target="_blank"
      rel="noopener noreferrer"
      class="flex-1 flex items-center justify-center gap-2 py-3.5 px-3 rounded-full bg-[#25D366] hover:bg-[#20ba5a] text-white font-display font-semibold text-[14px] shadow-[0_4px_20px_rgba(37,211,102,0.35)] transition-all active:scale-95"
      aria-label="WhatsApp Chat starten"
    >
      <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.117 1.528 5.845L.057 23.428a.5.5 0 0 0 .614.614l5.638-1.47A11.934 11.934 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.797 9.797 0 0 1-5.003-1.376l-.36-.214-3.724.97.993-3.63-.234-.374A9.797 9.797 0 0 1 2.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/>
      </svg>
      <span>WhatsApp</span>
    </a>

    <!-- Anruf CTA -->
    <a
      href="tel:+4915147736042"
      class="flex-1 flex items-center justify-center gap-2 py-3.5 px-3 rounded-full bg-orange hover:bg-orange-dark text-white font-display font-semibold text-[14px] shadow-[0_4px_20px_rgba(249,115,22,0.35)] transition-all active:scale-95"
      aria-label="Hundeschule anrufen"
    >
      <svg class="w-4 h-4 fill-none stroke-current" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span>Anrufen</span>
    </a>

    <!-- E-Mail CTA -->
    <a
      href="mailto:kontakt@wolfsknigge.de"
      class="w-12 h-12 flex-shrink-0 flex items-center justify-center rounded-full bg-anthrazit-3 border border-white/10 hover:border-orange/40 text-white shadow-[0_4px_16px_rgba(0,0,0,0.4)] transition-all active:scale-95"
      aria-label="E-Mail senden"
    >
      <svg class="w-5 h-5 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
    </a>

  </div>
</div>
