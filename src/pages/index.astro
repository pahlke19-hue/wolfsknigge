const features = [
  { nr: "01", icon: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>', title: "Mobil bei dir vor Ort", text: "Training in deiner Straße, deinem Park, deinem Wohnzimmer. Nicht auf einem fernen Hundeplatz." },
  { nr: "02", icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>', title: "Problemverhalten ist mein Alltag", text: "Leinenaggression, Angst, Jagdverhalten. Damit arbeite ich jeden Tag, nicht als Ausnahme." },
  { nr: "03", icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>', title: "Moderne Lerntheorie", text: "Klar, fair, gewaltfrei. Weder harter Drill noch reines Bestechen mit Futter." },
  { nr: "04", icon: '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/>', title: "Welpenstart mit Plan", text: "Erziehung, Sozialisierung und Umweltgewöhnung greifen von Tag eins ineinander. Das Fundament für einen entspannten Hund im echten Alltag." },
  { nr: "05", icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>', title: "1:1 Coaching", text: "Voller Fokus auf dich und deinen Hund. Maßgeschneidert, nicht von der Stange." },
  { nr: "06", icon: '<polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" x2="9" y1="3" y2="18"/><line x1="15" x2="15" y1="6" y2="21"/>', title: "4 Städte, 1 Trainer", text: "Kiel, Rendsburg, Eckernförde, Neumünster. Überall dieselbe Qualität, dieselbe Methode." },
