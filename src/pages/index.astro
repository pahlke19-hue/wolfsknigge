const prozess = [
  { step: "01", title: "Kennenlernen", text: "Kostenloses Erstgespräch per Telefon. Wir schauen, ob wir zueinander passen." },
  { step: "02", title: "Verhaltensanalyse", text: "Ausführliche Bestandsaufnahme bei dir vor Ort. Ich lerne euch im Alltag kennen." },
  { step: "03", title: "Klarer Fahrplan", text: "Ich gebe dir einen klaren, logisch aufgebauten Plan mit den ersten Trainingsschritten, damit ihr direkt loslegen könnt." },
  { step: "04", title: "Umsetzung", text: "Training dort, wo das Problem entsteht. Konsequent, fair, mit System." },
];

const testimonials = [
  { name: "Jori K.", text: "Die Trainingsanreize haben schnell geholfen und René nimmt sich wirklich Zeit für einen." },
  { name: "Susanne H.", text: "Als Ersthundebesitzer hatten wir viele Fragen, die uns schlüssig beantwortet wurden." },
  { name: "Daniela B.", text: "Dank des Trainings können wir endlich wieder entspannt Gassi gehen." },
  { name: "Jens", text: "Wir bekamen die Leinenaggression bei unserer Herdenschützerin super in den Griff." },
  { name: "Nicole H.", text: "Das Training hat schnell geholfen, sodass bei uns wieder Harmonie herrscht." },
  { name: "Sophia S.", text: "Dank des konsequenten Trainings klappt der Rückruf jetzt perfekt." },
  { name: "Mathias", text: "Wir lernen so viel Wichtiges, das uns super und schnell weiterhilft." },
  { name: "Claudia R.", text: "René hat uns geholfen, die Fehler im Umfeld zu sehen. Jetzt ist der Kleine entspannter." },
];

const vergleich = [
  { topic: "Trainingsort", hundeplatz: "Immer derselbe Hundeplatz", mobil: "Bei dir vor Ort. Dort, wo Probleme entstehen." },
  { topic: "Reizlage", hundeplatz: "Isoliert und eingezäunt", mobil: "Echter Alltag mit Joggern, Autos, anderen Hunden." },
  { topic: "Transfer", hundeplatz: "Funktioniert oft nur auf dem Platz", mobil: "Training findet direkt im Alltag statt." },
  { topic: "Betreuung", hundeplatz: "Große Gruppen, wenig Zeit pro Team", mobil: "1:1 oder kleine Gruppen. Voller Fokus." },
  { topic: "Methodik", hundeplatz: "Schema F für alle Hunde", mobil: "Individueller Plan nach moderner Lerntheorie." },
];

const faq = [
  {
    frage: "Ist mein Hund wirklich ein Fall für einen Trainer?",
    antwort: "Ehrlich gesagt: wahrscheinlich ja. Wenn du gerade hier auf dieser Seite gelandet bist, hattest du dafür vermutlich einen guten Grund. Ich erlebe oft, dass Halter viel zu lange warten, weil sie hoffen, dass sich das von alleine gibt. Tut es selten. Ob Leinenpöbeln, Angst oder einfach keine Basics, je früher wir anfangen, desto einfacher wird es. Ein kurzes Telefonat kostet nichts und bringt schon mal Klarheit."
  },
  {
    frage: "Ich war schon woanders. Warum sollte das hier anders sein?",
    antwort: "Kann ich absolut verstehen, dass du da skeptisch bist. Der Unterschied liegt nicht nur am Trainingsort, sondern auch an meiner detaillierten Herangehensweise und meiner ehrlichen, direkten Betreuung. Wir gehen nicht auf einen isolierten Hundeplatz, sondern genau dorthin, wo es bei euch knirscht. In deine Straße, deinen Park, deinen Alltag. Was dort funktioniert, funktioniert im echten Leben, kein reiner Übungsplatz-Effekt."
  },
  {
    frage: "Mein Hund ist sehr aggressiv. Geht das überhaupt?",
    antwort: "Genau das ist tatsächlich mein Schwerpunkt. Ich habe mich auf Problemverhalten spezialisiert und arbeite seit über fünf Jahren in dem Bereich. Aggression hat eigentlich immer eine Ursache, und meistens findet man die auch. Manchmal dauert es länger, manchmal überraschend kurz. Ich würde dir vorschlagen, dass wir einfach mal ein Erstgespräch machen und schauen, was bei euch tatsächlich los ist."
  },
  {
    frage: "Was kostet das Kennenlerngespräch?",
    antwort: "Nichts. Das erste Telefonat ist komplett kostenlos. Wir gucken in Ruhe, was bei euch tatsächlich los ist und ob ich der richtige Trainer für euch bin. Wenn ja, super. Wenn nicht, auch okay. Kein Verkaufsdruck, kein Pflichtgefühl."
  },
  {
    frage: "Ich wohne nicht direkt in Kiel. Kommt ihr auch zu mir?",
    antwort: "Ja, sehr wahrscheinlich. Ich bin mobil in einem Umkreis von ca. 35 km rund um Bredenbek unterwegs. Das deckt Kiel, Rendsburg, Eckernförde, Neumünster und das ganze Umland ab. Ruf einfach kurz an, dann klären wir die Details."
  },
  {
    frage: "Wie lange dauert es, bis ich Ergebnisse sehe?",
    antwort: "Wie lange so etwas dauert, kann man natürlich nie genau sagen. Erste Verbesserungen sind oft schon nach wenigen Einheiten spürbar, tiefergehende Verhaltensänderung braucht aber Zeit und vor allem Konsequenz im Alltag. Manchmal sind es genau die Hunde, bei denen man denkt, es dauert länger, wo es besonders gut klappt, aber das ist natürlich keine Garantie. Nach der Verhaltensanalyse sage ich dir ehrlich, was bei euch realistisch ist."
  },
];

const pressLogos = [
  { src: "/images/RTL_Nord_Logo.svg", alt: "RTL Nord", width: 140 },
  { src: "/images/Landeszeitung_Logo.svg", alt: "Landeszeitung", width: 160 },
