---
<Layout title="Mobile Hundeschule Kiel & Umgebung | WolfsKnigge" description="Mobile Hundeschule für Kiel, Rendsburg, Eckernförde & Neumünster. Spezialisiert auf Leinenaggression, Angst & Problemverhalten – Training bei dir vor Ort.">

  <!-- HERO -->
  <section id="hero" class="relative overflow-clip" style="min-height: 100svh; background: #000;">

    <div class="absolute inset-0">
      <picture class="block w-full h-full">
        <source media="(orientation: landscape)" srcset="/images/rene-hero.webp" width="1920" height="1280" />
        <img
          src="/images/rene_und_suka.webp"
          alt=""
          aria-hidden="true"
          id="hero-bg-img"
          class="w-full h-full object-cover object-[center_60%] landscape:object-[center_30%]"
          style="transform-origin: center; will-change: transform;"
          width="1080" height="1920"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
    </div>

    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0b] via-[rgba(10,10,11,0.45)] to-[rgba(10,10,11,0.1)]"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[rgba(10,10,11,0.65)] via-[rgba(10,10,11,0.15)] to-transparent"></div>
    <div class="absolute -top-[200px] right-[-100px] w-[600px] h-[600px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(249,115,22,.15), transparent 70%);"></div>

    <div class="relative flex flex-col justify-end" style="min-height: 100svh; padding-bottom: env(safe-area-inset-bottom, 0px);">
      <div class="w-full max-w-[1280px] mx-auto px-5 sm:px-8 lg:px-12 pb-20 pt-32 lg:pb-28">

        <div id="hero-badge" class="hero-reveal inline-flex items-center gap-2.5 bg-white/8 backdrop-blur-md border border-white/12 text-white font-medium text-[13px] px-4 py-2 rounded-full mb-7">
          <span class="relative flex h-2 w-2">
            <span class="relative inline-flex rounded-full h-2 w-2 bg-orange"></span>
          </span>
          Mobile Hundeschule · Schleswig-Holstein
        </div>

        <h1 class="font-display font-extrabold tracking-[-0.04em] leading-[0.92] mb-7">
          <span id="hero-line1" class="hero-reveal hero-reveal-d1 block text-[clamp(1.75rem,5.5vw,4.5rem)] text-white">Du liebst deinen Hund.</span>
          <span id="hero-line2" class="hero-reveal hero-reveal-d2 block text-[clamp(2rem,6vw,5rem)] text-gradient-orange italic">Aber gerade ist es</span>
          <span id="hero-line3" class="hero-reveal hero-reveal-d3 block text-[clamp(2.25rem,7vw,5.5rem)] text-white">einfach nur anstrengend.</span>
        </h1>

        <p id="hero-sub" class="hero-reveal hero-reveal-d4 text-[clamp(1rem,2vw,1.25rem)] text-white/60 mb-6 leading-relaxed max-w-[560px] font-light">
          Kenne ich, da war ich mit meinem ersten Hund auch. Ich bin René, mobiler Hundetrainer für <strong class="text-white font-medium">Kiel, Rendsburg, Eckernförde und Neumünster</strong>, spezialisiert auf genau solche Fälle. Wir trainieren bei dir vor Ort, nicht auf dem Hundeplatz.
        </p>

        <div id="hero-chips" class="hero-reveal hero-reveal-d4b mb-9">
          <span class="block text-white/45 text-[13px] font-light mb-2.5">Ich helfe dir bei:</span>
          <div class="flex flex-nowrap items-center gap-0.5 sm:gap-2.5">
            <span class="inline-flex items-center gap-1.5 whitespace-nowrap bg-white/[0.06] backdrop-blur-md border border-white/10 text-white/85 font-medium text-[clamp(0.5rem,2.5vw,0.8125rem)] px-1.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full">
              <span class="hidden sm:inline-block w-1.5 h-1.5 rounded-full bg-orange"></span>Leinenaggression
            </span>
            <span class="inline-flex items-center gap-1.5 whitespace-nowrap bg-white/[0.06] backdrop-blur-md border border-white/10 text-white/85 font-medium text-[clamp(0.5rem,2.5vw,0.8125rem)] px-1.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full">
              <span class="hidden sm:inline-block w-1.5 h-1.5 rounded-full bg-orange"></span>Angst
            </span>
            <span class="inline-flex items-center gap-1.5 whitespace-nowrap bg-white/[0.06] backdrop-blur-md border border-white/10 text-white/85 font-medium text-[clamp(0.5rem,2.5vw,0.8125rem)] px-1.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full">
              <span class="hidden sm:inline-block w-1.5 h-1.5 rounded-full bg-orange"></span>Jagdverhalten
            </span>
            <span class="inline-flex items-center gap-1.5 whitespace-nowrap bg-white/[0.06] backdrop-blur-md border border-white/10 text-white/85 font-medium text-[clamp(0.5rem,2.5vw,0.8125rem)] px-1.5 sm:px-3.5 py-1 sm:py-1.5 rounded-full">
              <span class="hidden sm:inline-block w-1.5 h-1.5 rounded-full bg-orange"></span>Welpenschule
            </span>
          </div>
        </div>

        <div id="hero-ctas" class="hero-reveal hero-reveal-d5 flex flex-col sm:flex-row gap-3.5 mb-12">
          <a href="/kontakt" class="shine group inline-flex items-center justify-center gap-2.5 rounded-full bg-orange text-white font-display font-semibold px-8 py-4 text-[15px] transition-all shadow-[0_0_60px_rgba(249,115,22,0.35)] active:scale-95 sm:hover:scale-[1.03] sm:hover:bg-orange-dark">
            Kostenloses Kennenlernen
            <svg class="w-[18px] h-[18px] sm:group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="#angebote" class="inline-flex items-center justify-center gap-2 rounded-full bg-white/6 backdrop-blur border border-white/15 text-white font-display font-semibold px-8 py-4 text-[15px] transition-all sm:hover:bg-white/12">
            Angebote ansehen
          </a>
        </div>

        <div id="hero-stats" class="hero-reveal hero-reveal-d6 flex items-center gap-8 pt-7 border-t border-white/8">
          <div>
            <div class="text-gradient-orange font-display font-extrabold text-2xl leading-none mb-0.5">
              <span class="hero-counter" data-target="200" data-suffix="+">200+</span>
            </div>
            <div class="text-[11px] text-white/55 uppercase tracking-[0.12em] font-medium">Kunden-Teams</div>
          </div>
          <div class="w-px h-9 bg-white/10"></div>
          <a href="https://g.page/r/Cd7XaBPmJ5fKEAE" target="_blank" rel="noopener noreferrer" class="group/google" aria-label="Google-Bewertungen von WolfsKnigge ansehen">
            <div class="flex items-center gap-2 mb-0.5">
              <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <span class="text-gradient-orange font-display font-extrabold text-2xl leading-none hero-counter" data-target="5" data-decimal="1" data-suffix="">5,0</span>
              <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            </div>
            <div class="text-[11px] text-white/55 uppercase tracking-[0.12em] font-medium group-hover/google:text-white/70 transition-colors">14 Bewertungen ↗</div>
          </a>
          <div class="w-px h-9 bg-white/10"></div>
          <div>
            <div class="font-display font-extrabold text-2xl text-white leading-none mb-0.5">
              &lt; 24<span class="text-orange">h</span>
            </div>
            <div class="text-[11px] text-white/55 uppercase tracking-[0.12em] font-medium">Antwortzeit</div>
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-6 right-6 sm:right-8 text-white/55 flex flex-col items-center gap-1.5">
      <div class="w-px h-10 bg-gradient-to-b from-transparent to-white/30 scroll-line-anim"></div>
    </div>
  </section>

  <!-- SOCIAL PROOF STRIP -->
  <section class="relative bg-anthrazit-2 border-y border-white/4 py-10 overflow-hidden">
    <div class="text-center mb-6">
      <a href="https://g.page/r/Cd7XaBPmJ5fKEAE" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 hover:opacity-80 transition-opacity" aria-label="Google-Bewertungen von WolfsKnigge ansehen">
        <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
