---
import Layout from "../layouts/Layout.astro";

const walks = [
  {
    nr: "01",
    name: "Zusammen-Wachsen",
    untertitel: "Der Standard-Walk",
    fuerWen: "Für alle Teams, die alltagsnah trainieren und sich mit anderen Haltern austauschen wollen.",
