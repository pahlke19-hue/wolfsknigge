const fuerWen = [
  "Leinenaggression, Pöbeln gegen Hunde oder Menschen",
  "Angst, Unsicherheit, Stress im Alltag",
  "Probleme beim Alleinebleiben",
  "Jagdverhalten, fehlender Rückruf",
  "Konflikte im Mehrhundehaushalt",
  "Neuer Hund aus dem Tierschutz",
  "Welpe oder Junghund mit ersten Auffälligkeiten",
  "Du weißt nicht, wo du anfangen sollst",
