  { icon: '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>', title: "Live-Beobachtung", text: "Ich sehe euch in eurem echten Umfeld: zuhause, beim Gassi, an der Tür. Genau da, wo es bei euch tatsächlich passiert.", accent: "orange" },
  { icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>', title: "Erste Trainingsimpulse", text: "Du gehst nicht mit reiner Theorie nach Hause. Konkrete Übungen, die du sofort anwenden kannst, noch am selben Tag.", accent: "orange" },
  { icon: '<path d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z"/><circle cx="12" cy="12" r="10"/>', title: "Klarer Weg nach vorn", text: "Du weißt am Ende genau, woran wir arbeiten und in welcher Reihenfolge. Schluss mit dem Gefühl, in zehn Richtungen gleichzeitig zu rennen.", accent: "orange" },
  { icon: '<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>', title: "Erklärung statt Rätsel", text: "Du verstehst, warum dein Hund tut, was er tut. Dieses Verständnis verändert oft mehr als jede einzelne Übung.", accent: "orange" },
  { icon: '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>', title: "Druck raus, Klarheit rein", text: "Viele gehen mit dem Gefühl, endlich verstanden zu werden. Nicht beurteilt, sondern unterstützt.", accent: "orange" },
];

const vergleich = [
  { topic: "Ausgangslage", sofort: "Training ohne vollständiges Bild", anamnese: "Vollständige Analyse vor dem ersten Schritt" },
  { topic: "Ursachen", sofort: "Symptome werden behandelt", anamnese: "Ursachen werden erkannt und angegangen" },
  { topic: "Vorgehen", sofort: "Generisch, angepasst im Verlauf", anamnese: "Maßgeschneidert von Anfang an" },
  { topic: "Fortschritt", sofort: "Oft langsam durch Umwege", anamnese: "Effizienter durch klaren Startpunkt" },
  { topic: "Ergebnis nach Termin", sofort: "Einstieg ins Training", anamnese: "Klarer Weg + sofort umsetzbare Übungen" },
];

const ablauf = [
  { step: "01", title: "Vorgespräch", text: "Kurzer Telefonkontakt vorab. Ich komme nicht unvorbereitet zu euch, sondern kenne eure Situation schon, bevor ich vor der Tür stehe." },
  { step: "02", title: "Termin vor Ort", text: "90 Minuten bei euch zuhause oder an eurem Alltagsort. In Ruhe, ohne Zeitdruck, ganz auf euch konzentriert." },
  { step: "03", title: "Erste Übungen live", text: "Wir bleiben nicht beim Reden. Erste Übungen werden direkt ausprobiert, korrigiert und erklärt." },
  { step: "04", title: "Dein roter Faden", text: "Zum Schluss gehen wir gemeinsam durch, woran ihr als Nächstes arbeitet. Du weißt, wo ihr steht und wie der Weg weitergeht." },
