  { step: "02", title: "Termin vereinbaren", text: "Flexibel nach deinem Alltag, ob bei dir zuhause, im Park oder am Problem-Ort." },
  { step: "03", title: "Training vor Ort", text: "60 bis 90 Minuten intensive Arbeit. Du bekommst sofort umsetzbare Strategien mit nach Hause." },
