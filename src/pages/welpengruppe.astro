---
import Layout from "../layouts/Layout.astro";

// Nächster Kursstart – hier aktualisieren, sobald der Termin wechselt.
const kursstart = "Sonntag, 21.06. · 10:00 Uhr";

const inhalte = [
  { icon: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>', title: "Grundsignale", text: "Sitz, Platz, Rückruf & Co., spielerisch aufgebaut und vom ersten Tag an alltagstauglich." },
  { icon: '<path d="M4 16v-2.38C4 11.5 2.97 10.5 3 8c.03-2.72 1.49-6 4.5-6C9.37 2 10 3.8 10 5.5c0 3.11-2 5.66-2 8.68V16a2 2 0 1 1-4 0Z"/><path d="M20 20v-2.38c0-2.12 1.03-3.12 1-5.62-.03-2.72-1.49-6-4.5-6C14.63 6 14 7.8 14 9.5c0 3.11 2 5.66 2 8.68V20a2 2 0 1 0 4 0Z"/><path d="M16 17h4"/><path d="M4 13h4"/>', title: "Alltagstraining", text: "Leinenführigkeit, Impulskontrolle, Frustrationstoleranz und entspanntes Ruhe-/Deckentraining." },
  { icon: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>', title: "Sozialisierung", text: "Fairer, kontrollierter Umgang mit Artgenossen und fremden Menschen, kein Welpenchaos." },
  { icon: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>', title: "Umweltgewöhnung", text: "Gelassenheit bei Verkehr, Geräuschen und Alltagsreizen, Sicherheit statt Angst." },
  { icon: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>', title: "Wichtige Themen", text: "Stubenreinheit, Alleinbleiben und Beißhemmung, die Klassiker, die später Kopfschmerzen sparen." },
  { icon: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>', title: "Körpersprache & Q&A", text: "Lerne deinen Welpen lesen. Raum für deine individuellen Fragen, jede Stunde." },
];

const phasen = [
  { nr: "01", titel: "Sozialisierung", subtitel: "Das Ticket fürs Leben", text: "Was dein Welpe in den ersten Wochen lernt, an Hunden, Menschen und Reizen, prägt ihn ein Leben lang. Ich nutze dieses Fenster bewusst." },
  { nr: "02", titel: "Spielerisches Lernen", subtitel: "Motivation statt Drill", text: "Ich nutze die natürliche Neugier deines Welpen. Abwechslungsreiche Übungen, die Spaß machen, weil Lernen mit Freude einfach besser klebt." },
  { nr: "03", titel: "Bindung & Vertrauen", subtitel: "Ihr werdet zum Team", text: "Faires Training und gemeinsame positive Erlebnisse stärken eure Beziehung. Bindung ist nicht selbstverständlich, sie wird gemacht." },
  { nr: "04", titel: "Beratung für dich", subtitel: "Du bist Teil des Trainings", text: "Stubenreinheit, Alleinbleiben, Management im Alltag, plus alle Fragen, die dir auf der Zunge brennen. Du gehst nicht ratlos nach Hause." },
];

const unterschiede = [
  { nr: "01", titel: "Wirklich kleine Gruppe", text: "Max. 7 Teams. Jeder Welpe wird gesehen, keine 12-Hunde-Tobeplatz-Veranstaltung, bei der die Schüchternen unter die Räder kommen." },
  { nr: "02", titel: "Wechselnde Orte", text: "Kein fester Hundeplatz. Wir treffen uns dort, wo Alltag stattfindet, damit dein Welpe von Anfang an verschiedene Umgebungen kennenlernt." },
  { nr: "03", titel: "Du wirst mit trainiert", text: "Ich erziehe nicht deinen Welpen, ich bringe euch bei, ein Team zu werden. Du nimmst Werkzeuge mit, die nach dem Kurs weiterwirken." },
  { nr: "04", titel: "Spezialist für Problemverhalten", text: "Wer täglich mit Aggression, Angst und Stress arbeitet, weiß, was in der Welpenzeit den Unterschied macht. Vorbeugen statt reparieren." },
];

const schritte = [
  { step: "01", title: "Kurz anrufen", text: "Wir sprechen kurz: Alter deines Welpen, was er schon kennt, was du dir vorstellst." },
  { step: "02", title: "Platz reservieren", text: "Max. 7 Teams pro Gruppe, frühzeitig anmelden lohnt sich. Ich bestätige den Start." },
  { step: "03", title: "Loslegen", text: "Erste Stunde, ihr lernt euch und die Gruppe kennen. Ab da: 8 Termine, ein Team." },
];

const faq = [
  {
    frage: "Ab welchem Alter darf mein Welpe in die Gruppe?",
    antwort: "Sobald die Grundimmunisierung läuft, meist ab der 10. Lebenswoche. Optimal ist ein Einstieg bis zur 16. Woche, dann nutzen wir die sensible Sozialisierungsphase voll aus. Älter ist auch okay, dann passen wir die Inhalte an."
  },
  {
    frage: "Was, wenn mein Welpe sehr schüchtern oder ängstlich ist?",
    antwort: "Genau dafür ist die kleine Gruppe da. Wir setzen keinen Welpen unter Druck und nichts wird erzwungen. Schüchterne Hunde dürfen erst beobachten, dann mitmachen, in ihrem Tempo. Bei stärkeren Themen klären wir vorher, ob eine Einzelstunde der bessere Einstieg ist."
  },
  {
    frage: "Brauche ich Vorerfahrung mit Hunden?",
    antwort: "Nein. Die Gruppe ist ausdrücklich auch für Ersthundebesitzer. Du musst nichts wissen, nur bereit sein zu lernen. Die meisten meiner Teilnehmer haben ihren ersten Hund."
  },
  {
    frage: "Was muss ich mitbringen?",
    antwort: "Geschirr oder gut sitzendes Halsband, normale Leine (keine Flexi), kleine weiche Leckerli in größerer Menge, Trinkwasser für deinen Welpen und eine Decke fürs Ruhetraining. Für dich: festes Schuhwerk, wetterangepasste Kleidung."
  },
  {
    frage: "Was, wenn ich einen Termin verpasse?",
    antwort: "Kein Drama. Wir gehen die wichtigsten Inhalte in der nächsten Stunde kurz mit dir durch. Eine Nachholmöglichkeit innerhalb der laufenden Kurse ist meist möglich, frag einfach."
  },
  {
    frage: "Wo finden die Stunden statt?",
    antwort: "An wechselnden Orten im Umland von Kiel und Rendsburg. Für das Freispiel bauen wir einen sicher umzäunten Platz auf. Die genauen Adressen bekommst du jeweils vorher per Mail."
  },
];

const testimonials = [
  { name: "Jori K.", text: "Die Trainingsanreize haben schnell geholfen und es wird sich wirklich Zeit genommen." },
  { name: "Susanne H.", text: "Als Ersthundebesitzer hatten wir viele Fragen, die uns schlüssig beantwortet wurden." },
  { name: "Daniela B.", text: "Dank des Trainings können wir endlich wieder entspannt Gassi gehen." },  { name: "Nicole H.", text: "Das Training hat schnell geholfen, sodass bei uns wieder Harmonie herrscht." },
  { name: "Sophia S.", text: "Dank des konsequenten Trainings klappt der Rückruf jetzt perfekt." },
  { name: "Mathias", text: "Wir lernen so viel Wichtiges, das uns super und schnell weiterhilft." },];
---

<Layout title="Welpenschule & Welpengruppe – Kiel & Rendsburg | WolfsKnigge" description="Welpengruppe für den perfekten Start: Umweltgewöhnung, Sozialkontakt & Grundsignale. 8 Termine, max. 7 Teams – im Umland von Kiel & Rendsburg.">

  <!-- HERO -->
  <section class="relative overflow-clip" style="min-height: 72svh; background: #000;">

    <div class="absolute inset-0">
      <img
        src="/images/hundetraining_gruppenstunde.webp"
        alt=""
        aria-hidden="true"
        id="hero-bg-img-welp"
        fetchpriority="high"
        decoding="async"
        class="w-full h-full object-cover"
        style="object-position: center 40%; transform-origin: center; will-change: transform;"
        width="1920" height="1280"
      />
    </div>

    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0b] via-[rgba(10,10,11,0.65)] to-[rgba(10,10,11,0.15)]"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[rgba(10,10,11,0.9)] via-[rgba(10,10,11,0.35)] to-transparent"></div>
    <div class="absolute -top-[200px] right-[-100px] w-[600px] h-[600px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(249,115,22,.15), transparent 70%);"></div>

    <div class="relative flex flex-col justify-end text-white" style="min-height: 72svh; padding-bottom: env(safe-area-inset-bottom, 0px);">
      <div class="w-full max-w-[1280px] mx-auto px-5 sm:px-8 lg:px-12 pb-20 pt-32 lg:pb-28">

        <div class="hero-reveal inline-flex items-center gap-2.5 bg-white/8 backdrop-blur-md border border-white/12 text-white font-medium text-[13px] px-4 py-2 rounded-full mb-7">
          <span class="relative flex h-2 w-2">
            <span class="relative inline-flex rounded-full h-2 w-2 bg-orange"></span>
          </span>
          WelpenKnigge · Kiel · Rendsburg
        </div>

        <h1 class="font-display font-extrabold tracking-[-0.04em] leading-[0.92] mb-7">
          <span class="hero-reveal hero-reveal-d1 block text-[clamp(3rem,9vw,7.5rem)] text-white">Was er jetzt lernt,</span>
          <span class="hero-reveal hero-reveal-d2 block text-[clamp(3rem,9vw,7.5rem)] text-gradient-orange italic">bleibt ein Leben lang.</span>
        </h1>

        <p class="hero-reveal hero-reveal-d4 text-[clamp(1rem,2vw,1.25rem)] text-white/60 mb-9 leading-relaxed max-w-[560px] font-light">
          Die Welpenzeit kommt nur einmal.
          <span class="text-white font-medium">Nutz das Fenster, das sich nie wieder öffnet. Fair, fundiert und mit jeder Menge Spaß.</span>
        </p>

        <div class="hero-reveal hero-reveal-d5 flex flex-col sm:flex-row flex-wrap gap-3.5 mb-12">
          <a href="https://rene-pahlke-hundetraining.123hundeschule.de/kurse" target="_blank" rel="noopener noreferrer" class="shine group inline-flex items-center justify-center gap-2.5 rounded-full bg-orange text-white font-display font-semibold px-8 py-4 text-[15px] transition-all shadow-[0_0_60px_rgba(249,115,22,0.35)] active:scale-95 sm:hover:scale-[1.03] sm:hover:bg-orange-dark">
            Direkt buchen
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </a>
          <a href="/kontakt" class="inline-flex items-center justify-center gap-2.5 rounded-full bg-white/6 backdrop-blur border border-white/15 text-white font-display font-semibold px-8 py-4 text-[15px] transition-all sm:hover:bg-white/12">
            Platz anfragen
          </a>
          <a href="#einstieg" class="inline-flex items-center justify-center gap-2 rounded-full bg-white/6 backdrop-blur border border-white/15 text-white font-display font-semibold px-8 py-4 text-[15px] transition-all sm:hover:bg-white/12">
            Wie läuft's ab?
          </a>
        </div>

        <div class="hero-reveal hero-reveal-d6 flex items-center gap-8 pt-7 border-t border-white/8">
          <div>
            <div class="text-gradient-orange font-display font-extrabold text-2xl leading-none mb-0.5">8</div>
            <div class="text-[11px] text-white/55 uppercase tracking-[0.12em] font-medium">Termine</div>
          </div>
          <div class="w-px h-9 bg-white/10"></div>
          <div>
            <div class="font-display font-extrabold text-2xl text-white leading-none mb-0.5">60<span class="text-orange">′</span></div>
            <div class="text-[11px] text-white/55 uppercase tracking-[0.12em] font-medium">Pro Einheit</div>
          </div>
          <div class="w-px h-9 bg-white/10"></div>
          <div>
            <div class="font-display font-extrabold text-2xl text-white leading-none mb-0.5">Max. 7</div>
            <div class="text-[11px] text-white/55 uppercase tracking-[0.12em] font-medium">Teams</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- KURSSTART-BANNER -->
  <section class="bg-anthrazit-2 border-y border-white/6 py-5">
    <div class="max-w-[1280px] mx-auto px-5 sm:px-8 lg:px-12 flex justify-center">
      <a href="https://rene-pahlke-hundetraining.123hundeschule.de/kurse" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 bg-white/8 backdrop-blur-md border border-white/15 rounded-full px-5 py-2.5 text-[14px] sm:text-[15px] font-medium text-white text-center transition-all sm:hover:bg-white/14 sm:hover:border-orange/40">
        <span class="relative flex h-2 w-2 flex-shrink-0">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-orange opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-orange"></span>
        </span>
        Nächster Kursstart: <span class="font-display font-bold text-orange">{kursstart}</span>
      </a>
    </div>
  </section>

  <script>
    (() => {
      const els = document.querySelectorAll<HTMLElement>('.hero-reveal');
      els.forEach((el) => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(28px)';
      });
      const animate = () => {
        els.forEach((el) => {
          el.style.transition = 'opacity 1s cubic-bezier(0.16,1,0.3,1), transform 1s cubic-bezier(0.16,1,0.3,1)';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        });
      };
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => requestAnimationFrame(() => requestAnimationFrame(animate)));
      } else {
        requestAnimationFrame(() => requestAnimationFrame(animate));
      }
      const heroBg = document.getElementById('hero-bg-img-welp') as HTMLImageElement | null;
      if (heroBg && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
        const onScroll = () => {
          const scrollY = window.scrollY;
          const heroEl = heroBg.closest('section');
          if (!heroEl) return;
          if (scrollY > heroEl.offsetHeight) return;
          const p = scrollY / heroEl.offsetHeight;
          heroBg.style.transform = `scale(1.12) translateY(${p * 100}px)`;
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }
    })();
  </script>

  <!-- BIG STATEMENT -->
  <section class="relative py-32 md:py-48 bg-anthrazit overflow-hidden noise">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] rounded-full pointer-events-none" style="background: radial-gradient(circle, rgba(249,115,22,.08), transparent 60%);"></div>
    <div class="relative max-w-[900px] mx-auto px-5 sm:px-6 lg:px-8 text-center">
      <span class="reveal inline-block text-orange font-semibold uppercase text-[13px] tracking-[0.3em] mb-5">Worum's wirklich geht</span>
      <h2 class="reveal reveal-delay-1 text-3xl md:text-[clamp(2rem,6vw,4.5rem)] font-display font-extrabold text-white leading-[1.05] tracking-tight mb-6">
        Mehr als „Sitz" und „Platz".
        <span class="block text-gradient-orange mt-2">Ein Fundament fürs Leben.</span>
      </h2>
      <p class="reveal reveal-delay-2 text-[clamp(1rem,2vw,1.35rem)] text-white/50 max-w-[700px] mx-auto leading-relaxed font-light">
        In den ersten Lebenswochen entscheidet sich, wie dein Hund später durchs Leben geht. Ich helfe dir, diese Zeit bewusst zu nutzen, ohne Drill, ohne Druck.
      </p>
    </div>
  </section>

  <!-- ECKDATEN-STRIP -->
  <section class="py-16 bg-anthrazit-2">
    <div class="max-w-[1200px] mx-auto px-5 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { label: "Kursdauer", value: "8 Termine" },
          { label: "Pro Einheit", value: "60 Minuten" },
          { label: "Gruppengröße", value: "Max. 7 Teams" },
          { label: "Region", value: "Kiel & Rendsburg" },
        ].map((d) => (
          <div class="reveal bg-anthrazit-3 rounded-[20px] p-6 border border-white/4 text-center">
            <div class="text-[11px] uppercase tracking-[0.2em] text-orange font-semibold mb-2">{d.label}</div>
            <div class="font-display font-bold text-white text-lg">{d.value}</div>
          </div>
        ))}
      </div>
      <p class="mt-5 text-white/55 text-sm text-center">Wechselnde Orte im Umland, damit dein Welpe verschiedene Umgebungen kennenlernt</p>
    </div>
  </section>

  <!-- SOCIAL PROOF MARQUEE -->
  <section class="relative bg-anthrazit-2 border-y border-white/4 py-10 overflow-hidden">
    <div class="text-center mb-6">
      <a href="https://g.page/r/Cd7XaBPmJ5fKEAE" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2.5 hover:opacity-80 transition-opacity" aria-label="Google-Bewertungen von WolfsKnigge ansehen">
        <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div class="flex gap-[3px]">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <span class="text-white font-semibold text-sm">5,0 auf Google · 14 Bewertungen · Über 200 betreute Teams <span class="text-white/55">↗</span></span>
      </a>
    </div>
    <div class="relative">
      <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-anthrazit-2 to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-anthrazit-2 to-transparent z-10 pointer-events-none"></div>
      <div class="flex animate-marquee-fast whitespace-nowrap">
        {[...testimonials, ...testimonials].map((t) => (
          <div class="inline-flex items-start gap-3 bg-white/4 border border-white/6 rounded-2xl px-5 py-4 min-w-[300px] max-w-[300px] flex-shrink-0 mr-3">
            <div class="flex-shrink-0 w-9 h-9 rounded-full bg-orange/15 border border-orange/25 flex items-center justify-center text-orange font-display font-bold text-sm">
              {t.name.charAt(0)}
            </div>
            <div>
              <div class="flex items-center gap-2 mb-1.5">
                <div class="flex gap-0.5">
                  {[1,2,3,4,5].map(() => (
                    <svg class="w-2.5 h-2.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                </div>
                <span class="text-white text-xs font-semibold">{t.name}</span>
              </div>
              <p class="text-white/55 text-[13px] leading-snug whitespace-normal">{t.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TRAININGSINHALTE -->
  <section id="inhalte" class="py-24 md:py-32 bg-anthrazit-2">
    <div class="max-w-[1200px] mx-auto px-5 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <span class="reveal inline-block text-orange font-semibold uppercase text-[13px] tracking-[0.3em] mb-4">Trainingsinhalte</span>
        <h2 class="reveal reveal-delay-1 text-4xl md:text-6xl font-display font-extrabold text-white tracking-tight leading-[1.05]">
          Was dein Welpe<br/>
          <span class="text-gradient-orange">bei mir lernt.</span>
        </h2>
        <p class="reveal reveal-delay-2 text-lg text-white/50 mt-6 font-light">Sechs Bausteine, die ineinandergreifen und die du im Alltag sofort merkst.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {inhalte.map((t, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} group relative bg-anthrazit-3 rounded-[20px] p-7 border border-white/4 hover:bg-anthrazit-4 hover:-translate-y-1 transition-all duration-500 overflow-hidden`}>
            <div class="absolute -top-8 -right-8 w-24 h-24 bg-orange/0 rounded-full group-hover:bg-orange/8 transition-colors blur-xl pointer-events-none"></div>
