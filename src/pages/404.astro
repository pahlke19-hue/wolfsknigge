---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Seite nicht gefunden | WolfsKnigge" description="Diese Seite existiert nicht. Zurück zur Startseite der mobilen Hundeschule WolfsKnigge." noindex={true}>

  <section class="relative overflow-clip pt-32 pb-28 lg:pt-40 lg:pb-36">
    <div class="absolute -top-[150px] right-[-100px] w-[500px] h-[500px] rounded-full pointer-events-none blob-float" style="background: radial-gradient(circle, rgba(249,115,22,.1), transparent 70%);"></div>

    <div class="relative max-w-[680px] mx-auto px-5 sm:px-8 text-center">
      <div class="inline-flex items-center bg-white/8 backdrop-blur-md border border-white/12 text-white/70 font-semibold text-[11.5px] uppercase tracking-[0.16em] px-3.5 py-1.5 rounded-full mb-6">
        Fehler 404
      </div>
      <h1 class="font-display font-extrabold tracking-[-0.035em] leading-[1.05] text-white text-[clamp(2.4rem,7vw,4rem)] mb-5">
        Diese Fährte führt ins Leere
      </h1>
      <p class="text-white/55 text-[16px] leading-relaxed mb-10 max-w-[480px] mx-auto">
        Die gesuchte Seite gibt es nicht (mehr). Vielleicht ein Tippfehler in der Adresse – oder der Inhalt ist umgezogen.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="shine inline-flex items-center justify-center gap-2.5 rounded-full bg-orange hover:bg-orange-dark text-white font-display font-semibold px-8 py-4 text-base transition-all shadow-[0_0_40px_rgba(249,115,22,0.25)] active:scale-98"
        >
          Zur Startseite
        </a>
        <a
          href="/kontakt"
          class="inline-flex items-center justify-center gap-2.5 rounded-full bg-white/8 hover:bg-white/12 border border-white/12 text-white font-display font-semibold px-8 py-4 text-base transition-all active:scale-98"
        >
          Kontakt aufnehmen
        </a>
      </div>
    </div>
  </section>

</Layout>
